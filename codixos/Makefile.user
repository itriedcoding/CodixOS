# CodixOS User-Space Build Makefile
# Builds shell and utilities for Linux/WSL

CC = gcc
CFLAGS = -Wall -Wextra -O2 -I shell/include -I utils/include

BUILD_DIR = build

.PHONY: all shell utils clean

all: shell utils

shell:
	@echo "[BUILD] Building CodixOS Shell..."
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) -c shell/src/codix_shell.c -o $(BUILD_DIR)/codix_shell.o
	$(CC) $(CFLAGS) -c shell/src/commands.c -o $(BUILD_DIR)/commands.o
	$(CC) $(CFLAGS) -c shell/src/parser.c -o $(BUILD_DIR)/parser.o
	$(CC) $(CFLAGS) -c shell/src/builtins.c -o $(BUILD_DIR)/builtins.o
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/codix-sh $(BUILD_DIR)/codix_shell.o $(BUILD_DIR)/commands.o $(BUILD_DIR)/parser.o $(BUILD_DIR)/builtins.o
	@echo "[BUILD] Shell built: $(BUILD_DIR)/codix-sh"

utils:
	@echo "[BUILD] Building System Utilities..."
	@mkdir -p $(BUILD_DIR)/bin
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-ls utils/src/ls.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-cat utils/src/cat.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-cp utils/src/cp.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-mv utils/src/mv.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-rm utils/src/rm.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-mkdir utils/src/mkdir.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-echo utils/src/echo.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-grep utils/src/grep.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-chmod utils/src/chmod.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-ps utils/src/ps.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-kill utils/src/kill.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-df utils/src/df.c
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/bin/codix-free utils/src/free.c
	@echo "[BUILD] Utilities built in $(BUILD_DIR)/bin/"

terminal:
	@echo "[BUILD] Building Terminal Emulator..."
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/codix-term terminal/src/terminal.c
	@echo "[BUILD] Terminal built: $(BUILD_DIR)/codix-term"

pkgmanager:
	@echo "[BUILD] Building Package Manager..."
	@mkdir -p $(BUILD_DIR)
	$(CC) $(CFLAGS) -o $(BUILD_DIR)/codix-pkg pkgmanager/src/codix_pkg.c
	@echo "[BUILD] Package manager built: $(BUILD_DIR)/codix-pkg"

clean:
	@echo "[BUILD] Cleaning build directory..."
	@rm -rf $(BUILD_DIR)
	@echo "[BUILD] Clean complete"
